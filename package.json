{
    "name": "ScreenCopy",
    "version": "0.1.3",
    "description": "Copy text from a screenshot",
    "main": "dist/main/main.js",
    "author": "Blobosle",
    "license": "GPL-3.0-only",
    "scripts": {
        "clean": "rm -rf build/ dist/main dist/renderer dist/shared dist/preload.js",
        "build:ts": "tsc -p tsconfig.json",
        "build:style": "npx @tailwindcss/cli -i src/renderer/style.css -o dist/renderer/style.css &> /dev/null",
        "build:style:watch": "npx @tailwindcss/cli -i src/renderer/style.css -o dist/renderer/style.css --watch",
        "build:renderer": "node ./scripts/build-renderer.mjs",
        "build:swift": "node ./scripts/build-swift-helper.mjs",
        "build:latex": "pyinstaller --clean --noconfirm --onedir --name latex-ocr-helper --add-data \".venv/lib/python3.11/site-packages/rapid_latex_ocr/config.yaml:rapid_latex_ocr\" --add-data \".venv/lib/python3.11/site-packages/rapid_latex_ocr/models:rapid_latex_ocr/models\" native/latex_ocr.py",
        "build": "npm run clean && npm run build:ts && npm run build:swift && npm run build:style && npm run build:renderer",
        "dev": "npm run build && electron . 2>&1",
        "watch": "npm run dev && npm run build:style:watch",
        "dist": "npm run build && npm run build:latex && electron-builder --mac dmg zip"
    },
    "build": {
        "appId": "com.blobosle.screencopy",
        "productName": "ScreenCopy",
        "files": [
            "dist/**/*",
            "package.json"
        ],
        "asar": true,
        "directories": {
            "output": "release"
        },
        "extraResources": [
            {
                "from": "build/native/ocr-helper",
                "to": "ocr-helper"
            },
            {
                "from": "dist/latex-ocr-helper",
                "to": "latex-ocr-helper"
            }
        ],
        "mac": {
            "category": "public.app-category.productivity",
            "target": [
                "zip",
                "dmg"
            ],
            "icon": "assets/icons/icon.icns"
        }
    },
    "devDependencies": {
        "@types/node": "25.4.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "electron": "41.0.1",
        "electron-builder": "26.8.1",
        "esbuild": "^0.27.4",
        "typescript": "5.9.3"
    },
    "dependencies": {
        "@tailwindcss/cli": "^4.2.2",
        "lucide-react": "^0.577.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwindcss": "^4.2.2"
    }
}
