{
    "name": "ScreenCopy",
    "version": "0.1.2",
    "description": "Copy text from a screenshot",
    "main": "dist/main/main.js",
    "author": "Blobosle",
    "license": "GPL-3.0-only",
    "scripts": {
        "clean": "rm -rf build/ dist/",
        "build:ts": "tsc -p tsconfig.json",
        "build:renderer": "node ./scripts/build-renderer.mjs",
        "build:swift": "node ./scripts/build-swift-helper.mjs",
        "build": "npm run clean && npm run build:ts && npm run build:swift && npm run build:renderer",
        "dev": "npm run build && electron . 2>&1 | tee snaptext-dev.log",
        "dist": "npm run build && electron-builder --mac dmg zip"
    },
    "build": {
        "appId": "com.blobosle.screencopy",
        "productName": "ScreenCopy",
        "files": [
            "dist/**/*",
            "package.json"
        ],
        "asar": true,
        "directories": {
            "output": "release"
        },
        "extraResources": [
            {
                "from": "build/native/ocr-helper",
                "to": "ocr-helper"
            }
        ],
        "mac": {
            "category": "public.app-category.productivity",
            "target": [
                "zip",
                "dmg"
            ]
        }
    },
    "devDependencies": {
        "@types/node": "25.4.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "electron": "41.0.1",
        "electron-builder": "26.8.1",
        "esbuild": "^0.27.4",
        "typescript": "5.9.3"
    },
    "dependencies": {
        "@tailwindcss/cli": "^4.2.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwindcss": "^4.2.2"
    }
}
