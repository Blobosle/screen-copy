{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "types": ["node"],
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@renderer/*": ["src/renderer/*"],
            "@shared/*": ["src/shared/*"],
            "@main/*": ["src/main/*"],
        },
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
    "exclude": ["dist", "node_modules"]
}
